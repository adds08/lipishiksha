
datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

model FontConfiguration {
  id               String    @id @default(cuid())
  name             String
  assignedLanguage String
  characters       String // Storing as JSON string for simplicity, could be a separate model
  fileName         String
  fileSize         BigInt    // Using BigInt as file size can exceed standard Int
  storagePath      String    // Local file system path or cloud storage identifier
  downloadURL      String    // Publicly accessible URL for the font
  createdAt        DateTime  @default(now())
}
